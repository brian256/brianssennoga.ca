---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allWriting = await getCollection('writing', ({ data }) => !data.draft);
const allThoughts = await getCollection('thoughts');

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });

// Define categories with keyword matching
const categories = [
  { id: 'ai',         label: 'AI & Machine Learning',     keywords: ['AI', 'ai', 'machine learning', 'Machine Learning', 'AI Policy', 'AI Literacy'] },
  { id: 'governance', label: 'Governance & Policy',        keywords: ['Governance', 'Policy', 'governance', 'policy'] },
  { id: 'newcomers',  label: 'Immigration & Newcomers',    keywords: ['Immigration', 'Newcomers', 'Newcomer', 'immigration'] },
  { id: 'leadership', label: 'Leadership & Management',    keywords: ['Leadership', 'Management', 'leadership', 'management'] },
  { id: 'family',     label: 'Family',                     keywords: ['Family', 'family'] },
  { id: 'satire',     label: 'Satire',                     keywords: ['Satire', 'satire'] },
  { id: 'personal',  label: 'Personal',                   keywords: ['Personal', 'personal', 'Humour', 'humour'] },
];

// Build a combined item list per category
function matchesCategory(tags: string[], keywords: string[]) {
  return tags.some(t => keywords.includes(t));
}

const categoryItems = categories.map(cat => {
  const thoughts = allThoughts
    .filter(t => t.data.tag && matchesCategory([t.data.tag], cat.keywords))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  const writing = allWriting
    .filter(w => matchesCategory(w.data.tags, cat.keywords))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return { ...cat, thoughts, writing };
});
---

<BaseLayout
  title="My Written Thoughts — Brian Ssennoga"
  description="Writing on AI Literacy, Policy & Governance, Human Capital Development, Immigration, Leadership, and more — from Edmonton, Alberta and beyond."
  pathname="/written-thoughts/"
>
  <section style="background: var(--bg); padding-block: clamp(2.5rem, 5vw, 4rem);">
    <div class="w">
      <div class="section-head">
        <span class="eyebrow">My Written Thoughts</span>
        <h2>Ideas, arguments, and the occasional provocation.</h2>
        <p class="lede">Organised by theme. Find whatever thread you're following.</p>
      </div>
    </div>

    {categoryItems.map(cat => (
      <div class="cat-section">
        <div class="w">
          <div class="cat-label">{cat.label}</div>
          <div class="card-list">

            {cat.writing.map(w => (
              <a href={`/writing/${w.slug}/`} class="card">
                <div class="card-meta">
                  <span>{fmtDate(w.data.date)}</span>
                  <span class="tag">Essay</span>
                </div>
                <h3 class="card-title">{w.data.title}</h3>
                <p class="card-exc">{w.data.description}</p>
                <span class="card-more">Read →</span>
              </a>
            ))}

            {cat.thoughts.map(t => (
              <a href={t.data.url} target="_blank" rel="noopener" class="card">
                <div class="card-meta">
                  <span>{fmtDate(t.data.date)}</span>
                  <span class="tag">{t.data.source}</span>
                </div>
                <h3 class="card-title">{t.data.title}</h3>
                <p class="card-exc">{t.data.excerpt}</p>
                <span class="card-more">Read on {t.data.source} →</span>
              </a>
            ))}

            {cat.writing.length === 0 && cat.thoughts.length === 0 && (
              <div class="card" style="opacity: 0.4; pointer-events: none; cursor: default;">
                <div class="card-meta"><span>Coming soon</span></div>
                <h3 class="card-title">First article in this category coming soon</h3>
                <p class="card-exc">Drafting in Google Drive — will appear here once published.</p>
              </div>
            )}

          </div>
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
