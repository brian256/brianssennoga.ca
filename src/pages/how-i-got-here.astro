---
import BaseLayout from '../layouts/BaseLayout.astro';

/*
  HOW TO UPDATE THIS PAGE
  ━━━━━━━━━━━━━━━━━━━━━━━
  Write the full chapter narratives in a single Google Drive document.
  Structure the doc with 5 sections, one per chapter, in this order:
    1. My Roots & Upbringing
    2. Family
    3. Development Sector Work
    4. Human Capital Development
    5. Technology Sector Work

  Include image captions and photo references in the doc.
  Bring the finished doc to Claude and say "publish How I Got Here."
  Claude will parse the doc and replace the placeholder content below.
*/

const chapters = [
  {
    n: '01', label: 'Foundation',
    title: 'My Roots & Upbringing',
    orgs: 'Uganda',
    narrative: [
      'Born and raised in Uganda. The formative years that shaped a particular way of seeing — where systems worked and where they didn\'t, who they served and who they left out.',
      'Every piece of work since has been shaped by that early lens — the instinct for what practical help actually looks like, and the frustration when well-intentioned systems miss the people they claim to serve.',
    ],
    img: null,
  },
  {
    n: '02', label: 'Anchor',
    title: 'Family',
    orgs: 'Edmonton, Alberta · Canada',
    narrative: [
      'The work is personal because the life is personal. Husband, father, and strategic advisor to the people closest to me — including daughter Gabriella, whose culinary career path is a live case study in the Human Capital Development work now offered through Olympia & Associates.',
      'Relocating to Edmonton with family was the Canada chapter beginning in full motion. The city, the country, and the people we\'ve built community with here are the daily anchor.',
    ],
    img: null,
  },
  {
    n: '03', label: 'Sector',
    title: 'Development Sector Work',
    orgs: 'Watoto · EGPAF · Global Health Corps',
    narrative: [
      'A decade of field-level work across East Africa\'s most significant Development and Health organisations. Watoto, the Elizabeth Glaser Pediatric AIDS Foundation, and Global Health Corps — each engagement sharpened the diagnostic instinct and deepened the commitment to the people implementing policy, not just writing it.',
      'This is where the lesson landed: the gap between a well-funded programme and a working one is almost always a human capital and systems problem — not a resource problem.',
    ],
    img: 'Image placeholder — development sector / East Africa field work',
  },
  {
    n: '04', label: 'Now',
    title: 'Human Capital Development',
    orgs: 'Global Health Corps · Kampala Leadership Hub · Olympia & Associates',
    narrative: [
      'The thread that ties everything together. From fellowship programming at Global Health Corps to founding the Kampala Leadership Hub in 2018 — a management consulting practice that delivered career coaching and a full management course for young team leaders and small business owners.',
      'After relocating to Edmonton, Olympia & Associates was established as a registered Alberta technology and business consulting practice. Five streams, one consistent question: does this actually reach the person it was designed for?',
    ],
    img: null,
  },
  {
    n: '05', label: 'Sector',
    title: 'Technology Sector Work',
    orgs: 'Watoto · Medic · LMH · Guild Digital Uganda · Amii',
    narrative: [
      'Information systems management at Watoto and LMH provided the NGO-sector ICT foundation. Medic — a global open-source community health technology organisation — introduced digital health at scale.',
      'The most substantive technology work came through Guild Digital Uganda — a registered nonprofit technology company with seven staff and three years of sustained operation. The flagship product, rCHMIS, served 780,000+ refugees at 83% health worker adoption, integrated with Uganda\'s Ministry of Health and extended into Rwanda under a Memorandum of Understanding. More recently, engagement with Amii has connected the AI and Machine Learning ecosystem in Edmonton with the policy and Governance work now central to Olympia & Associates.',
    ],
    img: 'Image placeholder — rCHMIS / Technology & ICT work · Uganda',
  },
];
---

<BaseLayout
  title="How I Got Here — Brian Ssennoga"
  description="Five pivotal moments across Uganda and Canada — Development, Technology, and Human Capital Development work that shaped Brian Ssennoga's consulting practice."
  pathname="/how-i-got-here/"
>
  <section style="padding-block: clamp(2.5rem, 5vw, 4rem); background: var(--bg);">
    <div class="w">
      <div class="section-head">
        <span class="eyebrow">How I Got Here</span>
        <h2>Five pivotal moments</h2>
        <p class="lede">Building useful systems for people the system usually skips.</p>
      </div>

      <div class="chapters-list">
        {chapters.map(c => (
          <article class="chapter">
            <div class="ch-num">
              {c.n}
              <small>{c.label}</small>
            </div>
            <div>
              <h3 class="ch-title">{c.title}</h3>
              <p class="ch-orgs">{c.orgs}</p>
              <div class="ch-narrative">
                {c.narrative.map(para => <p>{para}</p>)}
              </div>
              {c.img && (
                <div class="ch-img" data-label={c.img} aria-hidden="true"></div>
              )}
            </div>
          </article>
        ))}
      </div>

      <p style="margin-top: 2rem;">
        <a href="/bio/" class="link">Read the full long-form story on the Bio page →</a>
      </p>
    </div>
  </section>
</BaseLayout>
