---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  pathname?: string;
}

const {
  title,
  description = 'Edmonton-based consultant working on AI Literacy, Policy & Governance, and Human Capital Development — including helping Newcomer professionals, couples, and families thrive in Canada. Serving clients across Alberta, Canada, Uganda, and East Africa.',
  ogImage = '/og-default.png',
  pathname = '/',
} = Astro.props;

const canonical = new URL(pathname, Astro.site ?? 'https://brianssennoga.ca').toString();
const seoKeywords = 'AI, Machine Learning, Technology, ICT, Development, Policy, Governance, Literacy, Edmonton, Alberta, Canada, Kampala, Uganda, East Africa, Africa, Newcomer, Human Capital, Consulting';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={seoKeywords} />
    <meta name="author" content="Brian Ssennoga" />
    <link rel="canonical" href={canonical} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://brianssennoga.ca').toString()} />
    <meta property="og:site_name" content="Brian Ssennoga" />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bssennoga" />
    <meta name="twitter:creator" content="@bssennoga" />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Brian Ssennoga",
      "url": "https://brianssennoga.ca",
      "sameAs": [
        "https://www.linkedin.com/in/bssennoga",
        "https://twitter.com/bssennoga",
        "https://github.com/brian256"
      ],
      "jobTitle": "Consultant — AI Literacy, Policy & Governance, Human Capital Development",
      "worksFor": {
        "@type": "Organization",
        "name": "Olympia & Associates",
        "url": "https://olympia-associates.ca"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Edmonton",
        "addressRegion": "AB",
        "addressCountry": "CA"
      },
      "knowsAbout": [
        "AI Policy", "AI Literacy", "Machine Learning Governance", "Technology Consulting",
        "ICT", "Human Capital Development", "Newcomer Settlement", "Career Consulting",
        "Development Sector", "East Africa", "Uganda", "Edmonton Alberta"
      ]
    })} />

    <link rel="alternate" type="application/rss+xml" title="Brian Ssennoga — Writing" href="/writing/rss.xml" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute; width: 1px; height: 1px; padding: 0;
    margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
  .skip-link:focus {
    position: static; width: auto; height: auto;
    margin: 1rem; padding: 0.5rem 1rem;
    background: var(--color-ink); color: var(--color-bg);
    clip: auto;
  }
</style>
