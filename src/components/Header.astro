---
const navItems = [
  { href: '/#chapters',    label: 'How I Got Here' },
  { href: '/#thoughts',   label: 'My Written Thoughts' },
  { href: '/bio/',         label: 'Bio' },
  { href: '/bucket-list/', label: 'Bucket List' },
];

const { pathname } = Astro.url;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="wordmark" aria-label="Brian Ssennoga — home">
      Brian Ssennoga<span class="dot">.</span>
    </a>
    <nav class="site-nav" aria-label="Main">
      {navItems.map(item => (
        <a
          href={item.href}
          aria-current={pathname === item.href ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
