---
const navItems = [
  { href: '/written-thoughts/', label: 'My Written Thoughts' },
  { href: '/bio/',              label: 'Bio' },
  { href: '/bucket-list/',      label: 'Bucket List' },
];
const { pathname } = Astro.url;
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="wordmark" aria-label="Brian Ssennoga — home">
      Brian Ssennoga<span class="dot">.</span>
    </a>
    <nav class="site-nav" aria-label="Main">
      {navItems.map(item => (
        <a href={item.href} aria-current={pathname.startsWith(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
